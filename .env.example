# ============================================
# CLERK AUTHENTICATION
# Get these from https://dashboard.clerk.com
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx

# Clerk redirect URLs (optional - uses defaults if not set)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================
# STRIPE PAYMENTS
# Get these from https://dashboard.stripe.com
# ============================================
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Stripe Price IDs (create these in your Stripe dashboard)
# Monthly plan: $49/month
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
# Yearly plan: $490/year
STRIPE_YEARLY_PRICE_ID=price_xxxxxxxxxxxx

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=https://trading-agent.live
NEXT_PUBLIC_API_BASE=https://your-backend-api.com
